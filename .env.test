# Environment variables used when running the integration tests (npm run test:integration).
# These override the simple defaults in compose.yml so the backend container uses the same
# tokens/secrets as the tests (see src/test-helpers/auth-constants.js).
GRANTS_UI_BACKEND_AUTH_TOKEN=test-token-test-token-test-token-test-token-test-t-64-chars-long
GRANTS_UI_BACKEND_ENCRYPTION_KEY=test-encryption-key-test-encryption-key-test-encry-64-chars-long
APPLICATION_LOCK_TOKEN_SECRET=test-application-lock-key-test-application-lock-ke-64-chars-long
ENCRYPTED_AUTH_JWT_SECRET=test-encrypted-auth-jwt-secret
PURGE_UNSUBMITTED_APPLICATIONS=